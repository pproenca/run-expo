# --- workspace build / cache ---
node_modules/
dist/
coverage/
*.tsbuildinfo
.tmp/
.cache/
.npm/
.pnpm-store/

# Built CLI artifacts — emitted by `pnpm build` (packages/app/scripts/build.mjs),
# shipped in the npm tarball via package.json "files" + a "prepack" hook, and
# rebuilt fresh in CI. Never tracked (a committed artifact drifts from source).
# `cli/` = the bundle; `LICENSE` = a synced copy of the root LICENSE for the tarball.
packages/app/cli/
packages/app/LICENSE

# --- local evidence / agent-tool state (never committed) ---
.scratch/
.artifacts/
.clawpatch/
.desloppify/
*.tgz
pnpm-debug.log*
.DS_Store
.env
.env.*

# Local evidence produced by --record and manual CLI runs
expo98.policy.json
*.har
*.memgraph

# Local project-agent skill installs. Only repo-owned skills are visible by
# default; promoting a new repo skill should require an intentional `git add -f`.
# `run-expo` is the single published consumer skill `npx skills add pproenca/run-expo`
# installs; repo-development skills live under docs/dev-skills/ (outside this scan path).
.agents/skills/*
!.agents/skills/run-expo/
!.agents/skills/run-expo/**

# Claude Code session/project state (harness-managed, never committed).
.claude/
