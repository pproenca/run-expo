{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node", "ws"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    ".scratch",
    ".desloppify",
    "src/**/node-shims.d.ts"
  ]
}
