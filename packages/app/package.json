{
  "name": "expo98",
  "version": "0.1.0",
  "description": "Local-first evidence CLI for Expo / React Native iOS work: inspect a running app over Hermes CDP, drive the iOS simulator, probe Metro, and capture redacted, reproducible evidence — every state-changing action behind a fail-closed policy gate.",
  "keywords": [
    "agent",
    "cdp",
    "cli",
    "evidence",
    "expo",
    "hermes",
    "ios",
    "metro",
    "react-native",
    "simulator"
  ],
  "homepage": "https://github.com/pproenca/expo98#readme",
  "bugs": {
    "url": "https://github.com/pproenca/expo98/issues"
  },
  "license": "MIT",
  "author": "Pedro Proença",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pproenca/expo98.git",
    "directory": "packages/app"
  },
  "bin": {
    "expo98": "./cli/expo98.mjs"
  },
  "files": [
    "cli/expo98.mjs",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "darwin"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@expo98/core": "workspace:*",
    "@expo98/domain": "workspace:*",
    "@expo98/expo-integration": "workspace:*",
    "@expo98/handlers-artifacts": "workspace:*",
    "@expo98/handlers-devtools": "workspace:*",
    "@expo98/handlers-interaction": "workspace:*",
    "@expo98/handlers-net-perf": "workspace:*",
    "@expo98/handlers-snapshot": "workspace:*",
    "@expo98/overlay-server": "workspace:*",
    "@expo98/protocols": "workspace:*",
    "effect": "^3.21.2",
    "esbuild": "0.25.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
