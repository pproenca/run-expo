{
  "name": "@expo98/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "expo98 reimagined — CLI shell (@effect/cli) + composition root: global flags, POSIX exit codes, --json|--plain|--ndjson envelope, command registry. Preserves both expo98/expo-ios bins.",
