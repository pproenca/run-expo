{
  "name": "expo98",
  "version": "0.1.0",
  "description": "Modernized expo98 local evidence CLI for Expo React Native work.",
  "type": "module",
  "bin": {
    "expo98": "./cli/expo98.mjs",
    "expo-ios": "./cli/expo-ios.mjs"
  },
  "scripts": {
    "build": "node scripts/build-bundled-cli.mjs",
    "doctor": "node cli/expo98.mjs --json doctor",
    "expo98": "node cli/expo98.mjs",
    "pack:check": "pnpm pack --dry-run --json",
    "prepack": "pnpm run build",
    "pretest": "pnpm run build && pnpm run typecheck",
    "test": "node --test tests/*.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "files": [
    "cli/",
    "README.md"
  ],
  "dependencies": {
    "ws": "^8.21.0"
  },
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.12",
    "typescript": "^6.0.3"
  }
}
