{
  "name": "expo98",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "expo98 — local evidence CLI for Expo / React Native iOS work, rebuilt on Effect-TS. pnpm workspace; the publishable CLI lives in packages/app.",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "lint": "oxlint",
    "format": "oxfmt --write --threads=1",
    "format:check": "oxfmt --check --threads=1",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "prepare": "node scripts/prepare-git-hooks.mjs"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/node": "^24.0.0",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
